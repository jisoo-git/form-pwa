rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /forms/{formId} {
      allow read: if true;
      allow write: if true;
    }
    match /responses/{responseId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
